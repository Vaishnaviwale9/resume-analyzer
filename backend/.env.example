# App
APP_NAME=AI Resume Analyzer
APP_ENV=development
DEBUG=true
SECRET_KEY=change-this-to-a-long-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALGORITHM=HS256

# Database
DATABASE_URL=postgresql://resume_user:resume_pass@db:5432/resume_analyzer
POSTGRES_USER=resume_user
POSTGRES_PASSWORD=resume_pass
POSTGRES_DB=resume_analyzer

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Google OAuth (optional)
GOOGLE_CLIENT_ID=

# Optional external AI provider (falls back to built-in heuristic engine if unset)
OPENAI_API_KEY=
